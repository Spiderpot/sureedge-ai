{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "TURBOPACK= sh -c 'npx prisma generate && npx next build'",
  "installCommand": "npm ci",
  "crons": [
    {
      "path": "/api/cron/scan",
      "schedule": "*/15 * * * *"
    }
  ],
  "functions": {
    "src/app/api/surebet/scan/route.ts": { "maxDuration": 30 },
    "src/app/api/ai/advisor/route.ts":   { "maxDuration": 30 },
    "src/app/api/odds/live/route.ts":    { "maxDuration": 15 },
    "src/app/api/cron/scan/route.ts":    { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY"    },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
