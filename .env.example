# SureEdge AI — Environment Variables Template
# Copy this file to .env and fill in your values

# ─── DATABASE (Required) ──────────────────────────
# For local dev with Docker: postgresql://sureedge:YOUR_PASSWORD@localhost:5432/sureedge_dev
# For Neon (free): postgresql://neondb_owner:xxx@ep-xxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://sureedge:CHANGE_ME@localhost:5432/sureedge_dev"
DIRECT_URL="postgresql://sureedge:CHANGE_ME@localhost:5432/sureedge_dev"

# ─── REDIS (Optional for MVP) ────────────────────
REDIS_URL="redis://:CHANGE_ME@localhost:6379/0"

# ─── AUTH (Required — auto-generate with the command below) ──
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="CHANGE_ME_GENERATE_96_CHAR_HEX"

# ─── ODDS API (Required for live odds) ───────────
# Get free key: https://the-odds-api.com
ODDS_API_KEY=""

# ─── APPLICATION ─────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="SureEdge AI"
LOG_LEVEL="debug"
CORS_ORIGINS="http://localhost:3000"
RATE_LIMIT_MAX="200"
RATE_LIMIT_WINDOW_MS="60000"
BCRYPT_ROUNDS="10"
