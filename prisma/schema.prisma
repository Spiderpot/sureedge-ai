// SureEdge AI — Production Prisma Schema v2.4.1
// Fixes: Added failedLoginCount, lockedUntil to User
//        Fixed Transaction missing @relation to User
//        Added RefreshToken model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  FREE
  PRO
  ENTERPRISE
  ADMIN
}

enum BetStatus {
  PENDING
  PLACED
  WON
  LOST
  CANCELLED
  REFUNDED
}

enum AlertType {
  SUREBET
  ODDS_DROP
  LIMIT_REACHED
  ACCOUNT_FLAGGED
  SYSTEM
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELLED
}

enum AutoBetStatus {
  ACTIVE
  PAUSED
  DISABLED
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  passwordHash      String
  role              UserRole  @default(FREE)
  balance           Float     @default(0)
  totalProfit       Float     @default(0)
  isActive          Boolean   @default(true)
  // Security: brute-force protection
  failedLoginCount  Int       @default(0)
  lockedUntil       DateTime?
  lastLogin         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  surebets          Surebet[]
  bets              Bet[]
  alerts            Alert[]
  subscriptions     Subscription[]
  autoBetRules      AutoBetRule[]
  predictionLogs    PredictionLog[]
  transactions      Transaction[]    // Fix: proper relation
  refreshTokens     RefreshToken[]

  @@index([email])
  @@index([role])
}

// Fix: explicit refresh token store (replaces 7-day cookie-only approach)
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique  // SHA-256 hash of the actual token
  isRevoked Boolean  @default(false)
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Bookmaker {
  id          String   @id @default(cuid())
  name        String   @unique
  logoUrl     String?
  isActive    Boolean  @default(true)
  reliability Float    @default(0.9)
  maxStake    Float?
  minStake    Float    @default(1.0)
  minOdds     Float?
  country     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  odds        Odds[]
  bets        Bet[]
}

model SportEvent {
  id          String   @id @default(cuid())
  sport       String
  league      String?
  homeTeam    String
  awayTeam    String
  startTime   DateTime
  status      String   @default("upcoming")
  externalId  String?  @unique
  createdAt   DateTime @default(now())

  odds        Odds[]
  surebets    Surebet[]

  @@index([sport])
  @@index([startTime])
  @@index([status])
}

model Odds {
  id            String      @id @default(cuid())
  bookmakerId   String
  eventId       String
  market        String      @default("h2h")
  outcome       String
  odds          Float
  previousOdds  Float?
  timestamp     DateTime    @default(now())

  bookmaker     Bookmaker   @relation(fields: [bookmakerId], references: [id])
  event         SportEvent  @relation(fields: [eventId], references: [id])

  @@index([eventId, bookmakerId])
  @@index([timestamp])
}

model Surebet {
  id            String     @id @default(cuid())
  userId        String?
  eventId       String
  profit        Float
  roi           Float
  arbPercentage Float      @default(0)
  confidence    Float      @default(0.8)
  status        String     @default("active")
  expiresAt     DateTime
  detectedAt    DateTime   @default(now())
  outcomes      String     // JSON string

  user          User?      @relation(fields: [userId], references: [id])
  event         SportEvent @relation(fields: [eventId], references: [id])
  bets          Bet[]

  @@index([status])
  @@index([expiresAt])
}

model Bet {
  id            String     @id @default(cuid())
  userId        String
  surebetId     String?
  bookmakerId   String
  eventId       String
  stake         Float
  odds          Float
  potentialWin  Float
  status        BetStatus  @default(PENDING)
  placedAt      DateTime   @default(now())
  settledAt     DateTime?

  user          User       @relation(fields: [userId], references: [id])
  surebet       Surebet?   @relation(fields: [surebetId], references: [id])
  bookmaker     Bookmaker  @relation(fields: [bookmakerId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([placedAt])
}

model Alert {
  id            String     @id @default(cuid())
  userId        String
  type          AlertType
  title         String
  message       String
  isRead        Boolean    @default(false)
  createdAt     DateTime   @default(now())

  user          User       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String
  plan            UserRole           @default(PRO)
  status          SubscriptionStatus @default(ACTIVE)
  stripeId        String?
  currentPeriodEnd DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user            User               @relation(fields: [userId], references: [id])
}

model AutoBetRule {
  id            String        @id @default(cuid())
  userId        String
  name          String
  sport         String?
  minProfit     Float         @default(1.0)
  maxStake      Float         @default(100)
  status        AutoBetStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id])
}

model PredictionLog {
  id            String   @id @default(cuid())
  userId        String
  eventId       String
  prediction    String
  actualResult  String?
  confidence    Float
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
}

// Fix: userId is now a proper FK relation
model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   // deposit, withdraw, profit, bet_stake, bet_return
  amount      Float
  description String?
  status      String   @default("completed")
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}
