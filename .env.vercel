# SureEdge AI — Vercel Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Paste each value into: Vercel Dashboard → Project → Settings → Environment Variables
# Set scope to: Production + Preview + Development (or Production only for secrets)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Neon gives you TWO connection strings:
#   - Pooled URL  (ends in ?sslmode=require)           → DATABASE_URL  (app queries)
#   - Direct URL  (same but without ?pgbouncer=true)   → DIRECT_URL   (migrations)
# Get both from: Neon Console → Your Project → Connection Details → Connection string

DATABASE_URL=postgresql://neondb_owner:REPLACE@ep-REPLACE.us-east-2.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://neondb_owner:REPLACE@ep-REPLACE.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_96_CHAR_HEX

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=SureEdge AI
# Set this AFTER first Vercel deploy (you'll see the URL)
NEXT_PUBLIC_APP_URL=https://REPLACE.vercel.app

# ─── Odds API ─────────────────────────────────────────────────────────────────
# Free plan: 500 requests/month — enough to demo the scanner
# Sign up at: https://the-odds-api.com
ODDS_API_KEY=REPLACE_WITH_ODDS_API_KEY

# ─── AI Advisor (Anthropic) ───────────────────────────────────────────────────
# Free credits available at: https://console.anthropic.com
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_KEY

# ─── Optional: Seed control ───────────────────────────────────────────────────
# Set to true only when running initial seed, then remove
ALLOW_SEED=false
SEED_DEMO_PASSWORD=REPLACE_WITH_DEMO_PASSWORD
SEED_ADMIN_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD
